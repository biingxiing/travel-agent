{
  auto_https off
  admin off
}

:80 {
  encode gzip

  @api path /api* /health
  handle @api {
    reverse_proxy api:3001
  }

  handle {
    header Content-Type "text/plain; charset=utf-8"
    respond "Travel Agent demo API is running. Add the Nuxt web service to docker-compose once apps/web is merged." 200
  }
}
