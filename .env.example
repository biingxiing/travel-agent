# LLM endpoint — required. Use the new LLM_* names (legacy OPENAI_* still work).
# There is NO default; the API will refuse to start without these.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_PLANNER=gpt-5.4
LLM_MODEL_FAST=codex-mini-latest
DATABASE_URL=postgresql://username:password@host/database?sslmode=require
API_BIND_HOST=127.0.0.1
API_PORT=3001
PUBLIC_HTTP_PORT=8080
# Primary browser entry should stay on the Caddy origin (same-origin web + api).
# If you run the frontend separately in local dev, change this to http://localhost:3000.
CORS_ORIGIN=http://localhost:8080
# Leave empty in compose so the browser continues to call same-origin /api through Caddy.
NUXT_PUBLIC_API_BASE=
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-password
# IMPORTANT: keep this fixed after first deployment.
# Changing it later invalidates existing login cookies.
AUTH_COOKIE_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=travel_agent_auth
# ReAct loop config
EVAL_RULE_WEIGHT=0.7
EVAL_THRESHOLD=90
EVAL_MAX_ITER=10
EVAL_REQUIRED_CATEGORIES=transport,lodging,attraction
SKILL_EXEC_TIMEOUT_MS=60000
